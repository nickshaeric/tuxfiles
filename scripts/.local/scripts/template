#!/usr/bin/env bash
set -euo pipefail

TEMPLATE_DIR="$HOME/Documents/templates"
[[ -d "$TEMPLATE_DIR" ]] || { echo "Error: $TEMPLATE_DIR not found"; exit 1; }

# Select template
template_file=$(find "$TEMPLATE_DIR" -type f -not -path "*/.git/*" 2>/dev/null \
    | fzf --prompt="Select a template: " --height 20 --border)
[[ -n "$template_file" ]] || { echo "No template selected. Exiting."; exit 0; }
template_file=$(realpath "$template_file")

# Select destination directory
search_dirs=("$HOME/Desktop" "$HOME/Developer" "$HOME/Documents" "$HOME/university")
dest_dir=$(fzf --prompt="Select destination directory: " --height 20 --border < <(
    for dir in "${search_dirs[@]}"; do
        find "$dir" -type d -not -path "*/.git*" 2>/dev/null
    done
))
[[ -n "$dest_dir" ]] || { echo "No destination selected. Exiting."; exit 0; }
dest_dir=$(realpath "$dest_dir")
[[ -d "$dest_dir" ]] || { echo "Error: Destination does not exist"; exit 1; }

# Optional rename
read -rp "Enter new filename (or press Enter to keep '$(basename "$template_file")'): " new_name
new_name="${new_name:-$(basename "$template_file")}"

# Copy file
cp "$template_file" "$dest_dir/$new_name"
echo "Copied $(basename "$template_file") → $dest_dir/$new_name"
